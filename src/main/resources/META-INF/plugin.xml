<idea-plugin>
    <id>com.documate</id>
    <name>DocuMate</name>
    <vendor>DocuMate</vendor>

    <description><![CDATA[
        AI-powered documentation generator for Kotlin and Java.<br/>
        Place the caret inside any function or class and invoke
        <b>Generate AI Documentation</b> to instantly generate KDoc/Javadoc using Claude.
    ]]></description>

    <idea-version since-build="241"/>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                parentId="tools"
                instance="com.documate.settings.DocuMateConfigurable"
                id="com.documate.settings.DocuMateConfigurable"
                displayName="DocuMate"
        />
    </extensions>

    <actions>
        <action
                id="DocuMate.GenerateDoc"
                class="com.documate.actions.GenerateDocAction"
                text="Generate AI Documentation"
                description="Generate KDoc/Javadoc for the current function or class using Gemini AI">

            <!-- Appears in right-click context menu inside the editor -->
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>

            <!-- Keyboard shortcut: Ctrl+Shift+D -->
            <keyboard-shortcut first-keystroke="ctrl shift D" keymap="$default"/>
        </action>
    </actions>
</idea-plugin>
